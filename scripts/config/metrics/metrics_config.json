{
  "backends": [
    {
      "immediatelyExport": {
        "name": "Runtime",
        "enable": true,
        "exporters": []
      }
    },
    {
      "batchExport": {
        "name": "LakeHouse",
        "enable": true,
        "exporters": [
          {
            "prometheusPushExporter": {
              "enable": true,
              "batchSize": 1000,
              "batchIntervalSec": 1,
              "failureQueueMaxSize": 3,
              "failureDataDir": "/home/sn/metrics/failure",
              "failureDataFileMaxCapacity": 1,
              "enabledInstruments": [
                "yr_nodes_cpu_allocatable",
                "yr_nodes_cpu_capacity",
                "yr_nodes_memory_allocatable",
                "yr_nodes_memory_capacity",
                "yr_cluster_cpu_capacity",
                "yr_cluster_cpu_allocatable",
                "yr_cluster_memory_capacity",
                "yr_cluster_memory_allocatable",
                "yr_instance_count",
                "yr_cluster_instance_total",
                "yr_sandbox_lifecycle_status",
                "yr_sandbox_requested_cpu_cores",
                "yr_sandbox_requested_memory_bytes",
                "yr_sandbox_cpu_usage_cores",
                "yr_sandbox_memory_usage_ratio",
                "yr_sandbox_memory_usage_bytes",
                "yr_sandbox_memory_limit_bytes"
              ],
              "initConfig": {
                "port": 9091
              }
            }
          }
        ]
      }
    }
  ]
}
