    deps = [":exec_service_proto"],
    visibility = ["//visibility:public"],
)

cc_grpc_library(
    name = "exec_service_cc_grpc",
    srcs = [":exec_service_proto"],
    grpc_only = True,
    deps = [":exec_service_cc_proto"],
    visibility = ["//visibility:public"],
)

