load("@rules_proto//proto:defs.bzl", "proto_library")
load("@com_github_grpc_grpc//bazel:cc_grpc_library.bzl", "cc_grpc_library")

# strip_import_prefix = "/proto/posix" makes protoc treat files as if they live
# at the workspace root's "proto/posix/" level, so `import "common.proto"` resolves
# correctly (matching the bare-filename imports used throughout all .proto files here).

# --- Leaf proto targets (no imports) ---

proto_library(
    name = "affinity_proto",
    srcs = ["affinity.proto"],
    strip_import_prefix = "/proto/posix",
    visibility = ["//visibility:public"],
)

cc_proto_library(
    name = "affinity_cc_proto",
    deps = [":affinity_proto"],
    visibility = ["//visibility:public"],
)

